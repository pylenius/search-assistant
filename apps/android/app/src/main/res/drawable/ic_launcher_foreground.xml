<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: a stylized magnifying glass centered in
     a 108×108 dp viewport (Android safe-zone is 66×66 dp inside that).
     Geometry copied from the iOS launcher icon for visual parity. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Lens ring -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="8"
        android:fillColor="#00000000"
        android:pathData="M 48 56 m -22 0 a 22 22 0 1 0 44 0 a 22 22 0 1 0 -44 0" />

    <!-- Handle -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 64 72 L 80 88" />

    <!-- Center dot -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M 48 56 m -4 0 a 4 4 0 1 0 8 0 a 4 4 0 1 0 -8 0" />
</vector>
